# ── Tripwire environment template ────────────────────────────────────────────
# Copy to .env and fill in. NEVER commit the real .env (it is gitignored).
# Not every service needs every var — see the comments.

# ── AI triage (triage-service, Phase 3) ──────────────────────────────────────
ANTHROPIC_API_KEY=
# Model id is verified against the claude-api reference when Phase 3 is built.
ANTHROPIC_MODEL=claude-sonnet-5

# ── Threat-intel enrichment (triage-service, Phase 3) ────────────────────────
ABUSEIPDB_API_KEY=
VIRUSTOTAL_API_KEY=

# ── Supabase (triage-service writes, dashboard reads) ────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=          # triage-service ONLY — never expose to the browser
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Wazuh indexer / OpenSearch (triage-service, Phase 3) ─────────────────────
# The triage service QUERIES ALERTS from the indexer (:9200), not the manager
# API. Run the triage service on TheHive-5 so this is localhost. The password is
# your wazuh-lab indexer admin password (check your wazuh-lab configuration).
WAZUH_INDEXER_URL=https://localhost:9200
WAZUH_INDEXER_USER=admin
WAZUH_INDEXER_PASSWORD=

# How often to poll for new Cowrie alerts, and how long to wait after a
# session's last event before triaging it if it never sent a "closed" event.
POLL_INTERVAL_SECONDS=60
SESSION_GRACE_SECONDS=180

# ── Slack escalation (triage-service, SOAR tier 1) ───────────────────────────
# Post attacker sessions Claude scores >= threshold to a Slack incoming webhook.
# Leave blank to disable. The webhook URL is a secret — keep it in .env only,
# never commit it.
SLACK_WEBHOOK_URL=
SLACK_NOTIFY_THRESHOLD=4

# ── TheHive case creation (triage-service, SOAR tier 2) ──────────────────────
# Reuses the TheHive instance on the SIEM host. Blank api_key = disabled.
# Get the key from the TheHive UI: your user → Settings → API key. Secret —
# keep it in .env only.
THEHIVE_URL=http://localhost:9000
THEHIVE_API_KEY=
THEHIVE_CASE_THRESHOLD=4

# ── Honeypot listen ports (honeypot/docker-compose.yml, Phase 1) ─────────────
# LOCAL testing: keep the 2222/2223 defaults so you don't clash with real SSH.
# ON THE VPS: set these to 22 / 23 AFTER moving the real sshd to a high port.
SSH_LISTEN_PORT=2222
TELNET_LISTEN_PORT=2223

<!--
  Tripwire — custom Wazuh rules for Cowrie honeypot events.
  Install into the manager at /var/ossec/etc/rules/cowrie_rules.xml
  (see ../install-rules-on-manager.sh), then restart the manager.

  Cowrie emits JSON, so Wazuh's built-in json decoder already extracts the
  fields (eventid, src_ip, username, password, input, session, duration, ...).
  No custom DECODER is needed — these rules just classify and score the events.
  Field matches use pcre2 so the dots in eventids are matched literally.
-->
<group name="cowrie,honeypot,">

  <!-- Base: any Cowrie event. level 0 = don't alert on its own, just a parent. -->
  <rule id="100100" level="0">
    <decoded_as>json</decoded_as>
    <field name="eventid" type="pcre2">^cowrie\.</field>
    <description>Cowrie honeypot event.</description>
  </rule>

  <!-- New connection (recon / scanner touch). -->
  <rule id="100101" level="3">
    <if_sid>100100</if_sid>
    <field name="eventid" type="pcre2">^cowrie\.session\.connect$</field>
    <description>Cowrie: new connection from $(src_ip)</description>
    <group>recon,attack,</group>
  </rule>

  <!-- Failed login. -->
  <rule id="100102" level="4">
    <if_sid>100100</if_sid>
    <field name="eventid" type="pcre2">^cowrie\.login\.failed$</field>
    <description>Cowrie: failed login $(username):$(password) from $(src_ip)</description>
    <mitre>
      <id>T1110</id>
    </mitre>
    <group>authentication_failed,</group>
  </rule>

  <!-- Successful login (attacker is now "in"). -->
  <rule id="100103" level="6">
    <if_sid>100100</if_sid>
    <field name="eventid" type="pcre2">^cowrie\.login\.success$</field>
    <description>Cowrie: successful login $(username):$(password) from $(src_ip)</description>
    <mitre>
      <id>T1110</id>
    </mitre>
    <group>authentication_success,</group>
  </rule>

  <!-- Command executed in the fake shell. -->
  <rule id="100104" level="6">
    <if_sid>100100</if_sid>
    <field name="eventid" type="pcre2">^cowrie\.command\.input$</field>
    <description>Cowrie: command run by $(src_ip): $(input)</description>
    <mitre>
      <id>T1059</id>
    </mitre>
    <group>execution,</group>
  </rule>

  <!-- Unknown/failed command (still shows intent). -->
  <rule id="100105" level="4">
    <if_sid>100100</if_sid>
    <field name="eventid" type="pcre2">^cowrie\.command\.failed$</field>
    <description>Cowrie: unknown command attempted by $(src_ip): $(input)</description>
    <mitre>
      <id>T1059</id>
    </mitre>
    <group>execution,</group>
  </rule>

  <!-- File pulled onto the honeypot (malware staging). High signal. -->
  <rule id="100106" level="10">
    <if_sid>100100</if_sid>
    <field name="eventid" type="pcre2">^cowrie\.session\.file_download$</field>
    <description>Cowrie: file downloaded to honeypot from $(src_ip)</description>
    <mitre>
      <id>T1105</id>
    </mitre>
    <group>malware,</group>
  </rule>

  <!-- File uploaded via SCP/SFTP. -->
  <rule id="100107" level="10">
    <if_sid>100100</if_sid>
    <field name="eventid" type="pcre2">^cowrie\.session\.file_upload$</field>
    <description>Cowrie: file uploaded to honeypot from $(src_ip)</description>
    <mitre>
      <id>T1105</id>
    </mitre>
    <group>malware,</group>
  </rule>

  <!-- Attempt to tunnel/proxy through the box (using it as a relay). High signal. -->
  <rule id="100108" level="10">
    <if_sid>100100</if_sid>
    <field name="eventid" type="pcre2">^cowrie\.direct-tcpip\.request$</field>
    <description>Cowrie: outbound tunnel/proxy attempt from $(src_ip)</description>
    <mitre>
      <id>T1090</id>
    </mitre>
    <group>tunneling,</group>
  </rule>

</group>
